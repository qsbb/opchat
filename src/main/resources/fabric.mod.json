{
  "schemaVersion": 1,
  "id": "opchat",
  "version": "${version}",
  "name": "OpChat",
  "description": "替换原版聊天框的简单mod | A simple mod that replaces the vanilla chat screen",
  "authors": ["qsbb"],
  "contact": {
    "sources": "https://github.com/qsbb/opchat"
  },
  "license": "MIT",
  "icon": "assets/opchat/logo.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.opchat.ChatBubbleModClient"
    ],
    "main": [
      "com.opchat.ChatBubbleMod"
    ]
  },
  "mixins": ["opchat.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "~1.21.1",
    "java": ">=21"
  },
  "suggests": {
    "cloth-config": "*"
  }
}
